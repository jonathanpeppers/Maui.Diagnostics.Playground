#!/usr/bin/env sh
set -eu

GRADLE_VERSION="${GRADLE_VERSION:-8.14.3}"
BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
DIST_DIR="$BASE_DIR/.gradle/wrapper/dists/gradle-$GRADLE_VERSION-bin"
GRADLE_HOME="$DIST_DIR/gradle-$GRADLE_VERSION"
GRADLE_BIN="$GRADLE_HOME/bin/gradle"

if [ ! -x "$GRADLE_BIN" ]; then
  ZIP="$DIST_DIR/gradle-$GRADLE_VERSION-bin.zip"
  mkdir -p "$DIST_DIR"
  if [ ! -f "$ZIP" ]; then
    curl -fsSL "https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip" -o "$ZIP"
  fi
  unzip -q "$ZIP" -d "$DIST_DIR"
fi

exec "$GRADLE_BIN" "$@"
